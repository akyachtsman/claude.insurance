{
  "extraKnownMarketplaces": {
    "claude-directives": {
      "source": {
        "source": "github",
        "repo": "akyachtsman/claude.directives"
      }
    }
  },
  "enabledPlugins": {
    "directives-toolkit@claude-directives": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "frontend-design@claude-code-plugins": true
  },
  "permissions": {
    "allow": [
      "mcp__Claude_Code_Remote__send_later",
      "mcp__Claude_Code_Remote__list_triggers",
      "mcp__Claude_Code_Remote__delete_trigger"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/scripts/setup-playwright.sh >/tmp/setup-playwright.log 2>&1 &"
          }
        ]
      }
    ]
  }
}
